# --- JWT ---
JWT_SECRET=your-very-long-and-random-secret-key-at-least-32-chars
JWT_EXPIRATION_MS=86400000

# --- TMDB ---
TMDB_API_KEY=your_tmdb_api_key_here

# --- Cache ---
TMDB_MOVIE_CACHE_TTL_DAYS=7
RECOMMENDATION_DASHBOARD_CACHE_TTL_MINUTES=5

# --- E-mail (SMTP) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your_app_password

# --- Vertex AI (Gemini) ---
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.0-flash-001

# --- Frontend ---
# Origin for CORS (scheme + host only; browser sends this in Origin header)
CORS_ALLOWED_ORIGIN=https://jhermesn.dev
# Full URL for root redirect (where to send users who hit GET /)
FRONTEND_URL=https://jhermesn.dev/rekomenda-front